# ========================================================================================
# PHARMA-E ENVIRONMENT VARIABLES
# ========================================================================================

# ─── Supabase ───────────────────────────────────────────────────────────────────
# Frontend (exposed to browser via VITE_ prefix)
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"

# Backend (server-side only — NEVER prefix with VITE_)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_KEY="your-service-role-key"

# ─── Monnify ───────────────────────────────────────────────────────────────────
# Frontend SDK (for inline widget — optional if using server-side only)
VITE_MONNIFY_API_KEY="your-monnify-api-key"
VITE_MONNIFY_CONTRACT_CODE="your-contract-code"

# Backend (server-side — used by MonnifyAdapter)
MONNIFY_API_KEY="your-monnify-api-key"
MONNIFY_SECRET_KEY="your-monnify-secret-key"
MONNIFY_CONTRACT_CODE="your-contract-code"

# ─── Paystack ──────────────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY="sk_test_your-paystack-secret-key"

# ─── Cron ──────────────────────────────────────────────────────────────────────
# Used to authenticate cron endpoint (Vercel injects this automatically on Pro)
CRON_SECRET="your-cron-secret"
